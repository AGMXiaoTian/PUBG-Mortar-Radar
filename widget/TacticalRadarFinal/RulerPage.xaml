<Page x:Class="TacticalRadarFinal.RulerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#01000000">
    <Grid>
        <Canvas x:Name="RulerCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Ellipse x:Name="CrosshairDot" Width="4" Height="4" Fill="Lime" 
             HorizontalAlignment="Center" VerticalAlignment="Center" 
             Visibility="Collapsed" IsHitTestVisible="False" />

        <StackPanel x:Name="ControlPanel" Orientation="Horizontal" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 150, 0, 0">

            <Button Content="居中" Click="CenterWidget_Click" Margin="0,0,15,0" />

            <Button Content="准星" Click="ToggleCrosshair_Click" />
        </StackPanel>
    </Grid>
</Page>